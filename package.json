{
  "name": "arbol",
  "version": "3.13.3",
  "description": "An interactive org chart editor for the browser",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "org-chart",
    "organization",
    "hierarchy",
    "d3",
    "typescript",
    "pptx",
    "editor"
  ],
  "author": "Pedro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pedrofuentes/arbol.git"
  },
  "bugs": {
    "url": "https://github.com/pedrofuentes/arbol/issues"
  },
  "homepage": "https://arbol.pedrofuent.es",
  "type": "commonjs",
  "dependencies": {
    "d3": "^7.9.0",
    "exceljs": "^4.4.0",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/d3": "^7.4.3",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
